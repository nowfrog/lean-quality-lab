---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
const lang = 'en';

const news = [
  { date: 'April 2026', title: "World's Best Scientists 2026", text: 'Prof. Ioppolo is included in the World\'s Best Scientists 2026 "Business and Management" ranking by Research.com: D-Index 44, National Ranking 31, World Ranking 1364.', tag: 'Award', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7451248875392192512' },
  { date: 'April 2026', title: 'RII Forum 2026 \u2014 Athens', text: 'The LQS Lab team presented recent research results from the various active projects at the Research and Innovation Forum 2026 in Athens. Prof. Ioppolo is a steering committee member.', tag: 'Conference', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7394985924255875072', img: '/images/news/riiforum-2026.jpg', imgPos: 'top' },
  { date: 'April 2026', title: 'Elgar Encyclopedia of Life Cycle Sustainability Assessment', text: 'The Elgar Encyclopedia has been published. Prof. Ioppolo is the sole author of the entries: Closed loop, Urban metabolism, Urban resource harvesting.', tag: 'Publication', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7446176476632219648', img: '/images/news/elgar-encyclopedia.jpg', imgPos: 'top' },
  { date: 'March 2026', title: 'H-SMA-CE final paper on Sustainability', text: 'Published in open access the final paper of the PRIN H-SMA-CE project: "A Decision Support System for Sustainable Circular Economy Transition in Italian Historical Small Towns".', tag: 'Publication', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7444066705527660544', img: '/images/news/hsmace-paper.jpg', imgPos: 'top' },
  { date: 'March 2026', title: 'Nebrodi Project \u2014 Inner Area', text: 'Prof. Ioppolo and Prof. Limosani accepted the invitation from the Mayor of Brolo to develop a research project on the Nebrodi Inner Area (29 municipalities): urban metabolism, circularity and social inclusion.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7441121931229044736', },
  { date: 'February 2026', title: 'H-SMA-CE Website and PRIN 2022', text: 'Presentation of the PRIN 22 H-SMA-CE project, with PI Prof. Ioppolo and co-PI Prof. Arbolino. Project website launched.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7422696323801341952', img: '/images/news/hsmace-sito.jpg', imgPos: 'top' },
  { date: 'December 2025', title: 'DMO Taormina-Peloritani Perimetration Plan', text: 'Presented the Strategic Perimetration Plan, a preparatory document for the constitution of the Taormina-Peloritani Destination Management Organization. The plan defines the territorial boundaries and governance strategies for the future DMO.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7400614901959888896', img: '/images/news/dmo-taormina.jpg', imgPos: 'top' },
  { date: 'November 2025', title: 'MeTa Costa Blu \u2014 DMO', text: 'The MeTaBlue DMO is born \u2014 Messina Taormina Costa Blu. A sustainable local development model between innovation and tradition.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7386861913437024256', img: '/images/news/metablue.jpg' },
  { date: 'November 2025', title: 'GAL Taormina-Peloritani Strategic Plan', text: 'CNR-IRIB presented the Territorial Strategic Plan "Ecosystem of Excellence", developed with UniME support under Operative Project n. 1/2023.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7382763610885767168' },
  { date: 'September 2025', title: 'Strait of Messina Technical Committee', text: 'Prof. Ioppolo was appointed as expert member of the Ministerial Technical Committee for the dynamic crossing of the Strait of Messina.', tag: 'Appointment', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7371567425328136193' },
  { date: 'August 2025', title: 'Final results GAL Etna-Alcantara and Tirreno-Eolie', text: 'The LQS Lab presented the final results for both GAL projects. Prof. Ioppolo is PI of both: sustainability assessment across socio-cultural, economic and environmental dimensions.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7367526770520002560', img: '/images/news/gal-risultati.jpg' },
  { date: 'May 2025', title: 'DTS Conference 2025 \u2014 Paris', text: 'The UniME-Szczecin team presented scientific contributions at the Digital Transformation Society conference in Paris, with papers from PRIN and GAL projects.', tag: 'Conference', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7332384258772176896', img: '/images/news/dts-2025.jpg' },
  { date: 'April 2025', title: 'RII Forum 2025 \u2014 Barcelona', text: 'The lab team presented research results at the RII Forum in Barcelona. Prof. Ioppolo participated as panelist at the Round-Table Debate.', tag: 'Conference', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7323533342933434368', img: '/images/news/riiforum-2025.jpg' },
  { date: 'October 2024', title: 'Research week in Szczecin', text: 'After 10 years of cooperation with the University of Szczecin, a research and mobility week: meetings with Rector, Doctoral School, Space Technology Park, Maritime University and SGH Warsaw.', tag: 'Conference', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7253791100128157697' },
  { date: 'September 2024', title: 'AISME 2024 \u2014 PRIN and GAL Team', text: '22 years in the Italian Commodity Science Academy. The PRIN PNRR 22, PRIN 22 and GAL 23 team represented by D\'Alessandro, Licastro and Bongiorno.', tag: 'Conference' },
  { date: 'July 2024', title: 'Rector Delegate UniME', text: 'Prof. Ioppolo was appointed as Rector Delegate for relations with businesses and the territory at the University of Messina.', tag: 'Appointment', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7206605488812093440' },
  { date: 'May 2024', title: 'DTS Conference 2024 \u2014 Paris', text: 'Digital Transformation Society conference: presented ongoing results from PRIN and GAL projects, with Szopik-Depczy\u0144ska, Arbolino and D\'Alessandro.', tag: 'Conference', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7202228696747823105' },
  { date: 'January 2024', title: 'PRIN PNRR CE_IPSA Won', text: 'With Prof. Arbolino (PI) and Prof. Ioppolo (co-PI), the PRIN PNRR CE_IPSA project was won: development model for Circular Economy between industrial parks and surrounding areas.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7092906861577826304' },
  { date: 'December 2023', title: 'PRIN 2022 H-SMA-CE Won', text: 'Prof. Ioppolo (PI) and Prof. Arbolino (co-PI) won the PRIN 22: "H-SMA-CE: a decision support system for circular economy transition" in Italian historical small towns.', tag: 'Project', link: 'https://www.linkedin.com/feed/update/urn:li:activity:7083366175581061120' },
  { date: 'May 2023', title: 'Master Food 2nd Edition with Chamber of Commerce and ICE', text: 'Launch of the second edition of the Master in "Food, Quality and International Management" with Chamber of Commerce and ICE support for internationalization.', tag: 'Education', link: 'https://www.linkedin.com/feed/update/urn:li:activity:6934492898407141377' },
];
---

<BaseLayout title="News | LQS Lab UniME" lang={lang}>
  <PageHero label="News" title="Lab News" subtitle="Activities, events, publications and milestones of the Lean &amp; Quality Solutions Lab" />

  <section class="py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-px bg-dark-700"></div>
        <div class="space-y-8">
          {news.map((item, i) => (
            <div class={`reveal reveal-delay-${Math.min(i % 3 + 1, 3)} relative pl-12`}>
              <div class={`absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2 ${
                item.tag === 'Publication' ? 'bg-neon border-neon' :
                item.tag === 'Project' ? 'bg-cyan border-cyan' :
                item.tag === 'Conference' ? 'bg-gold border-gold' :
                item.tag === 'Award' ? 'bg-neon border-neon' :
                item.tag === 'Appointment' ? 'bg-dark-400 border-dark-400' :
                item.tag === 'Education' ? 'bg-cyan border-cyan' :
                'bg-dark-400 border-dark-400'
              }`}></div>
              <div class="bg-dark-900 border border-dark-700 rounded-xl overflow-hidden hover:border-dark-600 transition-colors">
                {item.img && (
                  <img src={item.img} alt={item.title} class={`w-full h-48 object-cover ${item.imgPos === 'top' ? 'object-top' : ''}`} loading="lazy" />
                )}
                <div class="p-5">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-dark-500">{item.date}</span>
                  <span class={`px-2 py-0.5 text-xs rounded-md font-mono ${
                    item.tag === 'Publication' ? 'bg-neon/5 border border-neon/10 text-neon/70' :
                    item.tag === 'Project' ? 'bg-cyan/5 border border-cyan/10 text-cyan/70' :
                    item.tag === 'Conference' ? 'bg-gold/5 border border-gold/10 text-gold/70' :
                    item.tag === 'Award' ? 'bg-neon/5 border border-neon/10 text-neon/70' :
                    item.tag === 'Appointment' ? 'bg-dark-800 border border-dark-700 text-dark-400' :
                    item.tag === 'Education' ? 'bg-cyan/5 border border-cyan/10 text-cyan/70' :
                    'bg-dark-800 border border-dark-700 text-dark-400'
                  }`}>{item.tag}</span>
                </div>
                <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">{item.title}</h3>
                <p class="text-sm text-dark-400 mt-2">{item.text}</p>
                {item.link && (
                  <a href={item.link} target="_blank" rel="noopener" class="inline-block mt-3 text-xs font-mono text-dark-500 hover:text-neon transition-colors">
                    View on LinkedIn &rarr;
                  </a>
                )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
