---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'en';
---

<BaseLayout title="Master Food, Quality & International Management | LQS Lab UniME" lang={lang}>
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}/images/projects/master-food/header.jpg`} alt="Food Quality Management" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="inline-block bg-black/40 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10">
      <span class="text-white font-mono text-sm tracking-widest uppercase">1st Level Master | UniME</span>
      <h1 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl lg:text-6xl font-bold text-white mt-4 leading-tight">Master Food, Quality &amp;<br/>International Management</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl">An integrated approach to studying and evaluating agri-food processes and products through quality management logic across the entire supply chain</p>
    </div></div>
  </section>
  <div class="gradient-line"></div>

  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="reveal bg-dark-900 border border-dark-700 rounded-2xl p-6 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Type</span>
            <p class="text-dark-100 font-mono mt-1">1st Level Master</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Duration</span>
            <p class="text-dark-100 font-mono mt-1">12 months</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Language</span>
            <p class="text-dark-100 font-mono mt-1">English</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Editions</span>
            <p class="text-dark-100 font-mono mt-1">3 (since 2021)</p>
          </div>
        </div>
      </div>

      <div class="reveal mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">The Master</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">Integrated training for the agri-food supply chain</h2>
        <p class="text-dark-400 leading-relaxed mb-4">The Master in <strong class="text-dark-100">Food, Quality and International Management</strong>, directed by Prof. Giuseppe Ioppolo at the Department of Economics, University of Messina, offers an integrated approach to studying and evaluating agri-food processes and products through quality management logic.</p>
        <p class="text-dark-400 leading-relaxed mb-4">The program combines <strong class="text-dark-100">social sciences, digital innovation and biology</strong>, preparing professionals capable of operating in global markets with advanced competencies in food quality, safety management, sustainability and circular economy.</p>
        <p class="text-dark-400 leading-relaxed">Teaching is characterized by a practical and dynamic model: theoretical sessions alternate with <strong class="text-dark-100">workshops, case studies, project work and internships</strong> at partner companies in the agri-food sector.</p>
      </div>

      <div class="reveal reveal-delay-1 mb-16">
        <span class="text-cyan font-mono text-xs tracking-widest uppercase">Learning Objectives</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">Key Competencies</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { title: 'Quality Management', desc: 'Quality management across the entire agri-food supply chain, from farm to fork, with TQM and Lean Thinking tools applied to the food sector.' },
            { title: 'Food Safety & Standards', desc: 'In-depth knowledge of international food safety standards (ISO 22000, HACCP, BRC, IFS) and European regulations.' },
            { title: 'International Management', desc: 'Managerial competencies for the internationalization of agri-food companies, with focus on export, marketing and market entry strategies.' },
            { title: 'Innovation & Food 5.0', desc: 'Emerging technologies and digital innovation applied to food: traceability, blockchain, IoT and supply chain sustainability.' },
          ].map(obj => (
            <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-colors">
              <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">{obj.title}</h3>
              <p class="text-sm text-dark-400 mt-2">{obj.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-gold font-mono text-xs tracking-widest uppercase">Editions</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">Three editions since 2021</h2>
        <div class="space-y-4">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5">
            <div class="flex items-center gap-3">
              <span class="text-neon font-mono text-sm font-bold">I</span>
              <div>
                <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">A.Y. 2021/2022</h3>
                <p class="text-sm text-dark-400">First edition with Italian and international students.</p>
              </div>
            </div>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5">
            <div class="flex items-center gap-3">
              <span class="text-cyan font-mono text-sm font-bold">II</span>
              <div>
                <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">A.Y. 2022/2023</h3>
                <p class="text-sm text-dark-400">Second edition, launched with Chamber of Commerce and ICE support for internationalization.</p>
              </div>
            </div>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5">
            <div class="flex items-center gap-3">
              <span class="text-gold font-mono text-sm font-bold">III</span>
              <div>
                <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">A.Y. 2023/2024</h3>
                <p class="text-sm text-dark-400">Third edition with expanded corporate partners and Food 5.0 focus.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-neon">3</p>
            <p class="text-xs text-dark-400 mt-1 font-mono uppercase">Editions</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-cyan">12</p>
            <p class="text-xs text-dark-400 mt-1 font-mono uppercase">Months</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-gold">EN</p>
            <p class="text-xs text-dark-400 mt-1 font-mono uppercase">Language</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-neon">1st</p>
            <p class="text-xs text-dark-400 mt-1 font-mono uppercase">Level</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2">
        <a href="https://www.unime.it/didattica/post-laurea/master-e-corsi-di-perfezionamento/total-quality-international-management-food" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 border border-dark-600 hover:border-neon/50 text-dark-300 hover:text-neon font-medium rounded-lg transition-all hover:bg-neon/5 text-sm">
          Official UniME page
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
