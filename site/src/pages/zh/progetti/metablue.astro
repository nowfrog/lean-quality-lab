---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const lang = 'zh';
---

<BaseLayout title="MeTaBlue - Messina Taormina Costa Blu | LQS Lab UniME" lang={lang}>
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/projects/metablue/taormina-panorama.jpg" alt="陶尔米纳全景" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="inline-block bg-black/40 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10">
      <span class="text-white font-mono text-sm tracking-widest uppercase">Destination Management Organization</span>
      <h1 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl lg:text-7xl font-bold text-white mt-4 leading-tight">MeTaBlue</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl">Messina Taormina Costa Blu &mdash; 从蓝色海岸到微型西西里的可持续发展统一模式</p>
    </div></div>
  </section>
  <div class="gradient-line"></div>

  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="reveal bg-dark-900 border border-dark-700 rounded-2xl p-6 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">类型</span>
            <p class="text-dark-100 font-mono mt-1">DMO</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">地区</span>
            <p class="text-dark-100 font-mono mt-1">Messina &ndash; Taormina</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">年份</span>
            <p class="text-dark-100 font-mono mt-1">2025</p>
          </div>
        </div>
      </div>

      <div class="reveal mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">项目概述</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">创新与传统之间的DMO</h2>
        <p class="text-dark-400 leading-relaxed mb-4"><strong class="text-dark-100">MeTaBlue &mdash; Messina Taormina Costa Blu</strong>是一个新的Destination Management Organization，统一了从Giardini Naxos到Messina之间的所有市镇。成立大会于2025年10月18日在陶尔米纳的Palazzo Duchi di Santo Stefano举行。</p>
        <p class="text-dark-400 leading-relaxed mb-4">该项目是多年来推广<strong class="text-dark-100">Costa Blu</strong>品牌作为卓越标志的自然延伸，构建一个能够共享战略、工具和资源的市镇网络，以提高服务标准、促进可持续性并打造强大、可识别和有竞争力的区域品牌。</p>
        <p class="text-dark-400 leading-relaxed">Ioppolo教授与Michele Limosani教授一起被委托开发指导该区域战略的可持续地方发展模式。</p>
      </div>

      <div class="reveal reveal-delay-1 mb-16">
        <div class="rounded-2xl overflow-hidden border border-dark-700">
          <img src="/images/projects/metablue/header.jpg" alt="MeTaBlue成立大会" class="w-full h-80 object-cover" loading="lazy" />
        </div>
        <p class="text-xs text-dark-400 italic mt-2">MeTaBlueDMO成立大会，Palazzo Duchi di Santo Stefano，陶尔米纳（2025年10月）</p>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-cyan font-mono text-xs tracking-widest uppercase">目标</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">关键策略</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">旅游整合</h3>
            <p class="text-sm text-dark-400 mt-2">创建连接海岸和山丘的路线和套餐：文化、体育、美食和自然旅游。</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-cyan/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">可持续交通</h3>
            <p class="text-sm text-dark-400 mt-2">徒步道、自行车道、配套休息区和使用氢电混合动力车辆的可持续旅游交通。</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-gold/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">区域品牌</h3>
            <p class="text-sm text-dark-400 mt-2">统一城市质量标准、蓝旗认证和推广国际认可的Costa Blu品牌。</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-gold font-mono text-xs tracking-widest uppercase">媒体报道</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">媒体中的项目</h2>
        <div class="space-y-3">
          {[
            { title: 'Nasce "METAblue": Messina e Taormina unite per il rilancio turistico', source: 'Tempostretto', url: 'https://www.tempostretto.it/news/nasce-metablue-messina-taormina-unite-rilancio-turistico.html' },
            { title: 'Costituzione del Distretto Turistico "MeTaBlue – Messina Taormina Costa Blu"', source: 'Il Sicilia', url: 'https://ilsicilia.it/costituzione-del-distretto-turistico-territoriale-metablue-messina-taormina-costa-blu-de-luca-modello-unitario-di-sviluppo-dalla-costa-blu-alla-sicilia-in-miniatura/' },
            { title: 'Distretto turistico "Messina-Taormina Costa Blu", si parte', source: 'SikilyNews', url: 'https://www.sikilynews.it/attualita/distretto-turistico-messina-taormina-costa-blu-si-parte-con-un-incarico-da-50mila-euro/20627' },
            { title: 'De Luca costituisce il Distretto Turistico Taormina-Messina-Costa Blu', source: 'Taormina News 24', url: 'https://taorminanews24.com/de-luca-costituisce-il-distretto-turistico-taormina-messina-costa-blu-incarico-da-50-mila-euro-ad-un-tecnico-di-messina/' },
          ].map(article => (
            <a href={article.url} target="_blank" rel="noopener" class="block bg-dark-900 border border-dark-700 rounded-xl p-4 hover:border-neon/20 transition-all group">
              <p class="font-[family-name:var(--font-display)] font-bold text-dark-100 group-hover:text-neon transition-colors">{article.title}</p>
              <p class="text-xs text-dark-500 font-mono mt-1">{article.source}</p>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
