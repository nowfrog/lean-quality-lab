---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { useTranslations } from '../i18n/utils';
const lang = 'it';
const t = useTranslations(lang);

// ============================================================
// CONFIGURAZIONE: sostituisci questi valori con i tuoi
// 1. Web3Forms: vai su https://web3forms.com, inserisci la tua
//    email e riceverai un access_key
// 2. hCaptcha: vai su https://www.hcaptcha.com, registrati
//    e ottieni il tuo sitekey
// ============================================================
const WEB3FORMS_KEY = '533b7cf2-359e-48b8-b878-42925dfef888';
const HCAPTCHA_SITEKEY = 'bd741316-789a-45d2-8d56-b31c46762252';
---

<BaseLayout title={t('contacts.title')} lang={lang}>
  <PageHero label={t('contacts.label')} title={t('contacts.h1')} subtitle={t('contacts.subtitle')} />
  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="reveal">
          <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mb-6">{t('contacts.form.title')}</h2>
          <form id="contact-form" class="space-y-5">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="Nuovo messaggio dal sito LQS Lab" />
            <input type="hidden" name="from_name" value="LQS Lab Website" />
            <!-- Honeypot anti-spam -->
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

            <div>
              <label for="name" class="block text-sm font-mono text-dark-400 mb-2">{t('contacts.form.name')}</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg bg-dark-900 border border-dark-700 text-dark-100 placeholder-dark-500 focus:ring-2 focus:ring-neon/50 focus:border-neon/50 outline-none transition-all" placeholder={t('contacts.form.name.ph')} />
            </div>
            <div>
              <label for="email" class="block text-sm font-mono text-dark-400 mb-2">{t('contacts.form.email')}</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-dark-900 border border-dark-700 text-dark-100 placeholder-dark-500 focus:ring-2 focus:ring-neon/50 focus:border-neon/50 outline-none transition-all" placeholder={t('contacts.form.email.ph')} />
            </div>
            <div>
              <label for="user-subject" class="block text-sm font-mono text-dark-400 mb-2">{t('contacts.form.subject')}</label>
              <input type="text" id="user-subject" name="user_subject" required class="w-full px-4 py-3 rounded-lg bg-dark-900 border border-dark-700 text-dark-100 placeholder-dark-500 focus:ring-2 focus:ring-neon/50 focus:border-neon/50 outline-none transition-all" placeholder={t('contacts.form.subject.ph')} />
            </div>
            <div>
              <label for="message" class="block text-sm font-mono text-dark-400 mb-2">{t('contacts.form.message')}</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg bg-dark-900 border border-dark-700 text-dark-100 placeholder-dark-500 focus:ring-2 focus:ring-neon/50 focus:border-neon/50 outline-none transition-all resize-none" placeholder={t('contacts.form.message.ph')}></textarea>
            </div>

            <!-- hCaptcha -->
            <div class="h-captcha" data-captcha="true" data-sitekey={HCAPTCHA_SITEKEY} data-theme="dark"></div>

            <!-- Status message -->
            <div id="form-status" class="hidden rounded-lg px-4 py-3 text-sm font-mono"></div>

            <button type="submit" id="submit-btn" class="magnetic-btn w-full px-6 py-3.5 bg-neon text-dark-950 font-bold rounded-lg transition-all hover:shadow-lg hover:shadow-neon/25 text-sm disabled:opacity-50 disabled:cursor-not-allowed">
              {t('contacts.form.send')}
            </button>
          </form>
        </div>
        <div class="reveal reveal-delay-2">
          <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mb-6">{t('contacts.where.title')}</h2>
          <div class="space-y-5 mb-8">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-lg bg-dark-800 border border-dark-700 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-neon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"></path></svg>
              </div>
              <div>
                <p class="font-[family-name:var(--font-display)] font-bold text-dark-100">{t('contacts.where.dept')}</p>
                <p class="text-sm text-dark-400 mt-1">Piazza Pugliatti, 1</p>
                <p class="text-sm text-dark-400">98122 Messina (ME), Italia</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-lg bg-dark-800 border border-dark-700 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-neon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"></path></svg>
              </div>
              <div>
                <p class="font-[family-name:var(--font-display)] font-bold text-dark-100">Email</p>
                <a href="mailto:giuseppe.ioppolo@unime.it" class="text-sm text-neon hover:underline mt-1 inline-block font-mono">giuseppe.ioppolo@unime.it</a>
              </div>
            </div>
          </div>
          <div class="rounded-2xl overflow-hidden border border-dark-700 h-72">
            <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=15.5465%2C38.1865%2C15.5565%2C38.1925&layer=mapnik&marker=38.1895%2C15.5515" class="w-full h-full border-0 grayscale contrast-125 opacity-80 hover:opacity-100 hover:grayscale-0 transition-all duration-500" loading="lazy" title={t('contacts.where.map')}></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- hCaptcha script -->
  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>

  <script is:inline define:vars={{ sendingText: t('contacts.form.sending'), successText: t('contacts.form.success'), errorText: t('contacts.form.error'), captchaText: t('contacts.form.captcha'), sendText: t('contacts.form.send') }}>
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const hcaptcha = form.querySelector('[name="h-captcha-response"]');
      if (!hcaptcha || !hcaptcha.value) {
        status.className = 'rounded-lg px-4 py-3 text-sm font-mono bg-yellow-500/10 border border-yellow-500/30 text-yellow-400';
        status.textContent = captchaText;
        return;
      }

      btn.disabled = true;
      btn.textContent = sendingText;
      status.className = 'hidden';

      try {
        const formData = new FormData(form);
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();

        if (data.success) {
          status.className = 'rounded-lg px-4 py-3 text-sm font-mono bg-neon/10 border border-neon/30 text-neon';
          status.textContent = successText;
          form.reset();
          if (typeof hcaptcha !== 'undefined' && window.hcaptcha) window.hcaptcha.reset();
        } else {
          throw new Error(data.message || 'Error');
        }
      } catch (err) {
        status.className = 'rounded-lg px-4 py-3 text-sm font-mono bg-red-500/10 border border-red-500/30 text-red-400';
        status.textContent = errorText;
      } finally {
        btn.disabled = false;
        btn.textContent = sendText;
      }
    });
  </script>
</BaseLayout>
