---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const lang = 'en';
---

<BaseLayout title="MeTaBlue - Messina Taormina Costa Blu | LQS Lab UniME" lang={lang}>
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/projects/metablue/taormina-panorama.jpg" alt="Taormina panorama" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="inline-block bg-black/40 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10">
      <span class="text-white font-mono text-sm tracking-widest uppercase">Destination Management Organization</span>
      <h1 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl lg:text-7xl font-bold text-white mt-4 leading-tight">MeTaBlue</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl">Messina Taormina Costa Blu &mdash; A unified model for sustainable development, from the Blue Coast to Sicily in miniature</p>
    </div></div>
  </section>
  <div class="gradient-line"></div>

  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="reveal bg-dark-900 border border-dark-700 rounded-2xl p-6 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Type</span>
            <p class="text-dark-100 font-mono mt-1">DMO</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Area</span>
            <p class="text-dark-100 font-mono mt-1">Messina &ndash; Taormina</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Year</span>
            <p class="text-dark-100 font-mono mt-1">2025</p>
          </div>
        </div>
      </div>

      <div class="reveal mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">The Project</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">A tourism district between innovation and tradition</h2>
        <p class="text-dark-400 leading-relaxed mb-4"><strong class="text-dark-100">MeTaBlue &mdash; Messina Taormina Costa Blu</strong> is a new Destination Management Organization uniting all municipalities between Giardini Naxos and Messina. The constitutional assembly was held on October 18, 2025, at Palazzo Duchi di Santo Stefano in Taormina.</p>
        <p class="text-dark-400 leading-relaxed mb-4">The project is the natural evolution of years of work promoting the <strong class="text-dark-100">Costa Blu</strong> brand as a mark of excellence, with a vision of a network of municipalities sharing strategies, tools and resources to raise service standards, promote sustainability and build a strong, recognizable and competitive territorial brand.</p>
        <p class="text-dark-400 leading-relaxed">Prof. Ioppolo, together with Prof. Michele Limosani, has been appointed to develop the sustainable local development model guiding the district's strategy.</p>
      </div>

      <div class="reveal reveal-delay-1 mb-16">
        <div class="rounded-2xl overflow-hidden border border-dark-700">
          <img src="/images/projects/metablue/header.jpg" alt="MeTaBlue constitutional assembly in Taormina" class="w-full h-80 object-cover" loading="lazy" />
        </div>
        <p class="text-xs text-dark-400 italic mt-2">MeTaBlue DMO constitutional assembly, Palazzo Duchi di Santo Stefano, Taormina (October 2025)</p>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-cyan font-mono text-xs tracking-widest uppercase">Objectives</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">Key Strategies</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">Tourism Integration</h3>
            <p class="text-sm text-dark-400 mt-2">Creating routes and packages connecting coast and hills: cultural, sports, food &amp; wine, and nature tourism.</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-cyan/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">Sustainable Mobility</h3>
            <p class="text-sm text-dark-400 mt-2">Hiking trails, cycling paths, equipped rest areas and sustainable tourism mobility with hybrid electric-hydrogen vehicles.</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-gold/20 transition-colors">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100">Territorial Brand</h3>
            <p class="text-sm text-dark-400 mt-2">Uniform urban quality standards, Blue Flag certifications and promotion of an internationally recognizable Costa Blu brand.</p>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-gold font-mono text-xs tracking-widest uppercase">Press Coverage</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">The project in the media</h2>
        <div class="space-y-3">
          {[
            { title: 'Nasce "METAblue": Messina e Taormina unite per il rilancio turistico', source: 'Tempostretto', url: 'https://www.tempostretto.it/news/nasce-metablue-messina-taormina-unite-rilancio-turistico.html' },
            { title: 'Costituzione del Distretto Turistico "MeTaBlue – Messina Taormina Costa Blu"', source: 'Il Sicilia', url: 'https://ilsicilia.it/costituzione-del-distretto-turistico-territoriale-metablue-messina-taormina-costa-blu-de-luca-modello-unitario-di-sviluppo-dalla-costa-blu-alla-sicilia-in-miniatura/' },
            { title: 'Distretto turistico "Messina-Taormina Costa Blu", si parte', source: 'SikilyNews', url: 'https://www.sikilynews.it/attualita/distretto-turistico-messina-taormina-costa-blu-si-parte-con-un-incarico-da-50mila-euro/20627' },
            { title: 'De Luca costituisce il Distretto Turistico Taormina-Messina-Costa Blu', source: 'Taormina News 24', url: 'https://taorminanews24.com/de-luca-costituisce-il-distretto-turistico-taormina-messina-costa-blu-incarico-da-50-mila-euro-ad-un-tecnico-di-messina/' },
          ].map(article => (
            <a href={article.url} target="_blank" rel="noopener" class="block bg-dark-900 border border-dark-700 rounded-xl p-4 hover:border-neon/20 transition-all group">
              <p class="font-[family-name:var(--font-display)] font-bold text-dark-100 group-hover:text-neon transition-colors">{article.title}</p>
              <p class="text-xs text-dark-500 font-mono mt-1">{article.source}</p>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
