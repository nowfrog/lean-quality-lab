---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { useTranslations } from '../../i18n/utils';
const lang = 'zh';
const t = useTranslations(lang);
const areas = ['lean','tqm','ce','i50','local','health'] as const;
---

<BaseLayout title={t('lab.title')} lang={lang}>
  <PageHero label={t('lab.label')} title={t('lab.h1')} />

  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="reveal">
          <span class="text-neon font-mono text-xs tracking-widest uppercase">{t('lab.mission.label')}</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold text-dark-100 mt-3 mb-6">{t('lab.mission.title')}</h2>
          <p class="text-dark-400 leading-relaxed text-lg">{t('lab.mission.text')}</p>
        </div>
        <div class="reveal reveal-delay-2">
          <span class="text-cyan font-mono text-xs tracking-widest uppercase">{t('lab.vision.label')}</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold text-dark-100 mt-3 mb-6">{t('lab.vision.title')}</h2>
          <p class="text-dark-400 leading-relaxed text-lg">{t('lab.vision.text')}</p>
        </div>
      </div>
    </div>
  </section>
  <div class="gradient-line max-w-7xl mx-auto"></div>

  <section class="py-24 lg:py-32 grid-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-neon font-mono text-sm tracking-widest uppercase reveal">{t('lab.goals.label')}</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl font-bold text-dark-100 mt-4 reveal reveal-delay-1">{t('lab.goals.title')}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {([{k:'goal1',d:1},{k:'goal2',d:2},{k:'goal3',d:3}] as const).map(g => (
          <div class={`reveal reveal-delay-${g.d} bg-dark-900 border border-dark-700 rounded-2xl p-6 card-hover`}>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-lg text-dark-100 mb-2">{t(`lab.${g.k}.title` as any)}</h3>
            <p class="text-sm text-dark-400">{t(`lab.${g.k}.text` as any)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <div class="gradient-line max-w-7xl mx-auto"></div>

  <section class="py-24 lg:py-32" id="ricerca">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-neon font-mono text-sm tracking-widest uppercase reveal">{t('research.label')}</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl font-bold text-dark-100 mt-4 reveal reveal-delay-1">{t('research.h1')}</h2>
        <p class="text-lg text-dark-400 mt-4 reveal reveal-delay-2">{t('research.subtitle')}</p>
      </div>
      <div class="space-y-6">
        {areas.map((key, i) => (
          <details class={`reveal reveal-delay-${Math.min(i+1,3)} group bg-dark-900 border border-dark-700 rounded-2xl overflow-hidden hover:border-neon/20 transition-colors duration-300`}>
            <summary class="flex items-center gap-5 p-6 cursor-pointer list-none select-none">
              <span class="font-mono text-sm text-neon/40 font-bold shrink-0">{String(i+1).padStart(2,'0')}</span>
              <div class="flex-1 min-w-0">
                <h3 class="font-[family-name:var(--font-display)] font-bold text-lg text-dark-100 group-hover:text-neon transition-colors duration-300">{t(`research.${key}.title` as any)}</h3>
                <p class="text-sm text-dark-400 mt-0.5 hidden sm:block">{t(`research.${key}.desc` as any)}</p>
              </div>
              <svg class="w-5 h-5 text-dark-500 group-open:rotate-180 transition-transform duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <div class="px-6 pb-6 pt-2 ml-[40px] sm:ml-[56px] border-t border-dark-800">
              <p class="text-dark-400 leading-relaxed">{t(`research.${key}.full` as any)}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
