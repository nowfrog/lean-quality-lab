---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { useTranslations } from '../../i18n/utils';
const lang = 'it';
const t = useTranslations(lang);

const projects = [
  { slug: 'h-sma-ce', name: 'H-SMA-CE', type: 'PRIN 2022, NextGenerationEU', desc: 'A Decision Support System for Sustainable Circular Economy Transition in Italian Historical Small Towns', budget: '€250.000', period: '2024-2027', img: '/images/projects/h-sma-ce/header.jpg' },
  { slug: 'ce-ipsa', name: 'CE_IPSA', type: 'PRIN, NextGenerationEU', desc: 'A Development Model for Circular Economy between Industrial Parks and Surrounding Areas', budget: '€266.000', period: '2023-2026', img: '/images/projects/ce-ipsa/header.jpg' },
  { slug: 'gal-tirreno-eolie', name: 'GAL Tirreno Eolie', type: 'Sviluppo locale', desc: 'Gruppo di Azione Locale per lo sviluppo del territorio tirrenico ed eoliano della Sicilia nord-orientale.', img: '/images/projects/gal-tirreno/header.jpg' },
  { slug: 'gal-etna-alcantara', name: 'GAL Etna-Alcantara', type: 'Sviluppo locale', desc: "Gruppo di Azione Locale per lo sviluppo dell'area etnea e della Valle dell'Alcantara.", img: '/images/projects/gal-etna/header.png' },
  { slug: 'metablue', name: 'MeTaBlue', type: 'DMO', desc: 'Messina Taormina Costa Blu — Un modello unitario di sviluppo sostenibile per la Riviera Jonica.', img: '/images/projects/metablue/riviera-jonica.jpg' },
  { slug: 'master-food', name: 'Master Food, Quality & International Management', type: 'Formazione', desc: 'Master di I livello in Food, Quality and International Management — Dipartimento di Economia, UniME.', img: '/images/projects/master-food/header.jpg' },
];
---

<BaseLayout title={t('projects.title')} lang={lang}>
  <PageHero label={t('projects.label')} title={t('projects.h1')} subtitle={t('projects.subtitle')} />
  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-10">
        <span class="text-dark-500 font-mono text-sm tracking-widest uppercase">Progetti completati</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {projects.map((p, i) => (
          <div class={`reveal reveal-delay-${Math.min(i+1,4)}`}>
            <a href={`/progetti/${p.slug}`} class="group relative block bg-dark-900 border border-dark-700 rounded-2xl overflow-hidden card-hover h-full">
              {p.img && (
                <div class="h-40 overflow-hidden">
                  <img src={p.img} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class="relative z-10 p-6">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <h3 class="font-[family-name:var(--font-display)] font-bold text-xl text-dark-100 group-hover:text-neon transition-colors duration-300">{p.name}</h3>
                    <span class="inline-flex items-center gap-1.5 mt-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-neon/50"></span>
                      <span class="text-xs font-mono text-neon/70 tracking-wide uppercase">{p.type}</span>
                    </span>
                  </div>
                  <div class="w-10 h-10 rounded-lg bg-dark-800 border border-dark-600 group-hover:border-neon/30 flex items-center justify-center transition-all duration-300 shrink-0">
                    <svg class="w-4 h-4 text-dark-500 group-hover:text-neon transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
                  </div>
                </div>
                <p class="text-sm text-dark-400 leading-relaxed mb-4">{p.desc}</p>
                {p.budget && (
                  <div class="flex gap-4 pt-4 border-t border-dark-700/50">
                    <span class="text-xs font-mono text-dark-500"><span class="text-neon/60">$</span> {p.budget}</span>
                    <span class="text-xs font-mono text-dark-500"><span class="text-neon/60">@</span> {p.period}</span>
                  </div>
                )}
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
