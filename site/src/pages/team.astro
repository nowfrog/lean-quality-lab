---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { useTranslations } from '../i18n/utils';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'it';
const t = useTranslations(lang);

const members = [
  {
    id: 'ioppolo',
    name: 'Giuseppe Ioppolo',
    role: t('team.coordinator'),
    subtitle: 'Professore Ordinario | ECON-10/A Scienze Merceologiche',
    dept: 'Dipartimento di Economia | UniME',
    bio: 'Ingegnere civile per l\'ambiente con focus su sostenibilità e gestione ambientale, è Professore Ordinario di Scienze Merceologiche e Docente di Tecnologia dei Cicli Produttivi e TQM presso il Dipartimento di Economia dell\'Università di Messina. È membro della Scuola Dottorale di Economics, Management and Statistics. È Delegato del Rettore per i Rapporti con le Imprese del Territorio. In qualità di Editor-in-Chief della rivista Sustainability, una delle principali riviste internazionali sul tema della sostenibilità, ha svolto il ruolo di referee per l\'Italia e l\'Europa in numerosi comitati scientifici di conferenze internazionali. Come Visiting Professor ha tenuto lezioni presso Tsinghua University (Pechino, Cina), BJTU MBA (Pechino, Cina), Tokyo University (Tokyo, Giappone) e Santa Barbara University (California, USA). È PI di diversi programmi internazionali ed è particolarmente attivo in Cina. Ha partecipato a programmi di ricerca nazionali e internazionali come Interreg e Horizon. Infine, ha svolto attività di coordinamento di processi in progetti di ingegneria e pianificazione territoriale, sia in Italia (Isole Eolie, Sardegna, Valle d\'Agrò, ecc.) che all\'estero (Tunisia, Croazia, ecc.).',
    tags: ['Economia Circolare', 'Ecologia Industriale', 'Sviluppo Sostenibile', 'Gestione Ambientale', 'Pianificazione Territoriale'],
    initials: 'GI',
    img: `${base}/images/team/ioppolo.jpg`,
    links: [
      { label: 'Scopus', url: 'https://www.scopus.com/authid/detail.uri?authorId=36097581800' },
      { label: 'ORCID', url: 'https://orcid.org/0000-0003-0262-8435' },
      { label: 'Scholar', url: 'https://scholar.google.com/citations?user=u0gVgvQAAAAJ&hl=en' },
      { label: 'ResearchGate', url: 'https://www.researchgate.net/profile/Giuseppe-Ioppolo' },
    ]
  },
  {
    id: 'dalessandro',
    name: "Carlotta D'Alessandro",
    role: t('team.researcher.f'),
    subtitle: 'PhD | XXXVI Ciclo EMS',
    dept: 'Dipartimento di Economia | UniME',
    bio: 'Dottoressa di ricerca in Economics, Management and Statistics con focus su Sostenibilità ed Economia Circolare presso l\'Università di Messina. La sua ricerca è dedicata ad affrontare questioni critiche nella sostenibilità e a promuovere pratiche di economia circolare, lavorando verso un futuro più sostenibile e circolare. Attualmente è Guest Editor per una rivista scientifica internazionale.',
    tags: ['Sostenibilità', 'Economia Circolare', 'Sviluppo Sostenibile', 'Gestione dell\'Innovazione Sostenibile', 'Ecologia Industriale'],
    initials: 'CD',
    img: `${base}/images/team/dalessandro.jpg`,
    links: [
      { label: 'Scopus', url: 'https://www.scopus.com/authid/detail.uri?authorId=58534571400' },
      { label: 'ORCID', url: 'https://orcid.org/0000-0002-7361-4201' },
      { label: 'Scholar', url: 'https://scholar.google.com/citations?user=6wedFFkAAAAJ&hl=it&oi=ao' },
    ]
  },
  {
    id: 'licastro',
    name: 'Antonio Licastro',
    role: t('team.researcher'),
    subtitle: 'PhD in Economics, Management and Statistics',
    dept: 'Dipartimento di Economia | UniME',
    bio: 'Assegnista di ricerca presso il Dipartimento di Scienze Umane e Sociali dell\'Università di Napoli "L\'Orientale". Ha conseguito il dottorato con lode nel 2025 presso l\'Università di Messina, Dipartimento di Economia. Le sue aree di competenza includono econometria, Life Cycle Assessment (LCA), ecologia industriale e scienza della sostenibilità, con focus sulle sfide ambientali critiche nei sistemi agricoli e territoriali. I suoi interessi di ricerca attuali includono lo sviluppo di metodologie di valutazione accessibili per le transizioni di sostenibilità nelle piccole comunità, l\'integrazione di tecnologie digitali nei sistemi di monitoraggio ambientale e l\'avanzamento delle basi teoriche delle applicazioni di economia circolare in contesti agricoli.',
    tags: ['Econometria', 'Life Cycle Assessment', 'Ecologia Industriale', 'Scienza della Sostenibilità', 'Economia Circolare'],
    initials: 'AL',
    img: `${base}/images/team/licastro.jpg`,
    links: [
      { label: 'Scopus', url: 'https://www.scopus.com/authid/detail.uri?authorId=57278726700' },
      { label: 'ORCID', url: 'https://orcid.org/0000-0002-4735-6237' },
      { label: 'Scholar', url: 'https://scholar.google.com/citations?hl=it&user=icXhf2EAAAAJ' },
    ]
  },
  {
    id: 'morana',
    name: 'Andrea Morana',
    role: t('team.phd'),
    subtitle: 'PhD Student',
    dept: 'Dipartimento di Economia | UniME',
    initials: 'AM',
    links: []
  },
];

const collaborators = [
  {
    id: 'szopik',
    name: 'Katarzyna Szopik-Depczyńska',
    role: 'Collaborazione internazionale',
    subtitle: 'Associate Professor | Management and Quality Sciences',
    dept: 'University of Szczecin | Polonia',
    bio: 'Professoressa Associata in Management presso l\'Università di Szczecin (Polonia), svolge il ruolo di Senior Researcher in Gestione dell\'Innovazione Sostenibile per il progetto H-SMA-CE. Il suo lavoro si concentra sull\'analisi dell\'innovazione tecnologica, sulle metodologie di economia circolare e sugli strumenti di valutazione ambientale per i piccoli centri storici, supportando lo sviluppo e il testing del DSS. Co-autrice frequente con il Prof. Ioppolo, vanta circa 170 pubblicazioni su Journal of Cleaner Production, Land Use Policy, Ecological Indicators. Co-autrice del libro "Total Quality Management and Lean Thinking 5.0" (Routledge, 2024).',
    tags: ['Innovation Management', 'R&D', 'Sostenibilità', 'CSR'],
    initials: 'KS',
    img: `${base}/images/team/szopik.jpg`,
    links: [
      { label: 'Scholar', url: 'https://scholar.google.pl/citations?user=lL4k3n0AAAAJ&hl=pl' },
      { label: 'ResearchGate', url: 'https://www.researchgate.net/profile/Katarzyna-Szopik-Depczynska' },
    ]
  },
];
---

<BaseLayout title={t('team.title')} lang={lang}>
  <PageHero label={t('team.label')} title={t('team.h1')} subtitle={t('team.subtitle')} />
  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Team members -->
      <div class="space-y-6">
        {members.map((m, i) => (
          <div id={m.id} class={`reveal reveal-delay-${Math.min(i+1,3)} group bg-dark-900 border border-dark-700 rounded-2xl overflow-hidden card-hover scroll-mt-24`}>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-center gap-4">
                  {m.img ? (
                    <img src={m.img} alt={m.name} class="w-14 h-14 rounded-full object-cover ring-2 ring-neon/20 shrink-0" loading="lazy" />
                  ) : (
                    <div class="w-14 h-14 rounded-full flex items-center justify-center bg-gradient-to-br from-dark-800 to-dark-700 ring-2 ring-dark-600 shrink-0">
                      <span class="font-[family-name:var(--font-display)] text-lg font-bold text-dark-500 group-hover:text-neon/30 transition-colors duration-500">{m.initials}</span>
                    </div>
                  )}
                  <div>
                    <h3 class="font-[family-name:var(--font-display)] font-bold text-lg text-dark-100">{m.name}</h3>
                    <p class="text-xs text-dark-400 mt-0.5">{m.subtitle}</p>
                    <p class="text-xs text-dark-500 font-mono">{m.dept}</p>
                  </div>
                </div>
                <span class="px-2.5 py-1 text-[10px] font-mono bg-dark-800 border border-neon/20 rounded-md text-neon uppercase tracking-wider shrink-0">{m.role}</span>
              </div>
              {m.bio && <p class="text-sm text-dark-400 mt-3 leading-relaxed">{m.bio}</p>}
              {m.tags && m.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {m.tags.map(tag => (
                    <span class="px-2 py-0.5 text-[10px] rounded-md bg-dark-800 border border-dark-700 text-dark-400 font-mono">{tag}</span>
                  ))}
                </div>
              )}
              {m.links && m.links.length > 0 && (
                <div class="flex flex-wrap gap-3 mt-3 pt-3 border-t border-dark-700/50">
                  {m.links.map(link => (
                    <a href={link.url} target="_blank" rel="noopener" class="text-xs text-dark-400 hover:text-neon transition-colors font-mono tracking-wide">{link.label}</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Collaborazione internazionale -->
      <div class="mt-16">
        <span class="text-cyan font-mono text-sm tracking-widest uppercase reveal">Collaborazione internazionale</span>
        <div class="space-y-6 mt-6">
          {collaborators.map((m, i) => (
            <div id={m.id} class={`reveal reveal-delay-1 group bg-dark-900 border border-cyan/20 rounded-2xl overflow-hidden card-hover scroll-mt-24`}>
              <div class="p-5">
                <div class="flex items-start justify-between gap-3">
                  <div class="flex items-center gap-4">
                    {m.img ? (
                      <img src={m.img} alt={m.name} class="w-14 h-14 rounded-full object-cover ring-2 ring-cyan/20 shrink-0" loading="lazy" />
                    ) : (
                      <div class="w-14 h-14 rounded-full flex items-center justify-center bg-gradient-to-br from-dark-800 to-dark-700 ring-2 ring-dark-600 shrink-0">
                        <span class="font-[family-name:var(--font-display)] text-lg font-bold text-dark-500 group-hover:text-cyan/30 transition-colors duration-500">{m.initials}</span>
                      </div>
                    )}
                    <div>
                      <h3 class="font-[family-name:var(--font-display)] font-bold text-lg text-dark-100">{m.name}</h3>
                      <p class="text-xs text-dark-400 mt-0.5">{m.subtitle}</p>
                      <p class="text-xs text-dark-500 font-mono">{m.dept}</p>
                    </div>
                  </div>
                  <span class="px-2.5 py-1 text-[10px] font-mono bg-dark-800 border border-cyan/20 rounded-md text-cyan uppercase tracking-wider shrink-0">{m.role}</span>
                </div>
                {m.bio && <p class="text-sm text-dark-400 mt-3 leading-relaxed">{m.bio}</p>}
                {m.tags && m.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {m.tags.map(tag => (
                      <span class="px-2 py-0.5 text-[10px] rounded-md bg-dark-800 border border-dark-700 text-dark-400 font-mono">{tag}</span>
                    ))}
                  </div>
                )}
                {m.links && m.links.length > 0 && (
                  <div class="flex flex-wrap gap-3 mt-3 pt-3 border-t border-dark-700/50">
                    {m.links.map(link => (
                      <a href={link.url} target="_blank" rel="noopener" class="text-xs text-dark-400 hover:text-cyan transition-colors font-mono tracking-wide">{link.label}</a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
