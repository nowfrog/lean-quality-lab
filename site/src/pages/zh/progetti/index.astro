---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import { useTranslations } from '../../../i18n/utils';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'zh';
const t = useTranslations(lang);

const projects = [
  { slug: 'h-sma-ce', name: 'H-SMA-CE', type: 'PRIN 2022, NextGenerationEU', desc: '意大利历史小镇可持续循环经济转型决策支持系统', budget: '€250.000', period: '2024-2027', img: `${base}/images/projects/h-sma-ce/header.jpg` },
  { slug: 'ce-ipsa', name: 'CE_IPSA', type: 'PRIN, NextGenerationEU', desc: '工业园区与周边地区之间循环经济的发展模式', budget: '€266.000', period: '2023-2026', img: `${base}/images/projects/ce-ipsa/header.jpg` },
  { slug: 'gal-tirreno-eolie', name: 'GAL Tirreno Eolie', type: '地方发展', desc: '西西里岛东北部第勒尼安海和伊奥利亚群岛地区发展的地方行动小组。', img: `${base}/images/projects/gal-tirreno/header.jpg` },
  { slug: 'gal-etna-alcantara', name: 'GAL Etna-Alcantara', type: '地方发展', desc: '埃特纳火山和阿尔坎塔拉河谷地区发展的地方行动小组。', img: `${base}/images/projects/gal-etna/header.png` },
  { slug: 'metablue', name: 'MeTaBlue', type: 'DMO', desc: 'Messina Taormina Costa Blu — 爱奥尼亚海岸可持续发展统一模式。', img: `${base}/images/projects/metablue/riviera-jonica.jpg` },
  { slug: 'master-food', name: 'Master Food, Quality & International Management', type: '教育', desc: '食品、质量与国际管理一级硕士 — 墨西拿大学经济系。', img: `${base}/images/projects/master-food/header.jpg` },
];
---

<BaseLayout title={t('projects.title')} lang={lang}>
  <PageHero label={t('projects.label')} title={t('projects.h1')} subtitle={t('projects.subtitle')} />
  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-10">
        <span class="text-dark-500 font-mono text-sm tracking-widest uppercase">已完成项目</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {projects.map((p, i) => (
          <div class={`reveal reveal-delay-${Math.min(i+1,4)}`}>
            <a href={`${base}/zh/progetti/${p.slug}`} class="group relative block bg-dark-900 border border-dark-700 rounded-2xl overflow-hidden card-hover h-full">
              {p.img && (
                <div class="h-40 overflow-hidden">
                  <img src={p.img} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class="relative z-10 p-6">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <h3 class="font-[family-name:var(--font-display)] font-bold text-xl text-dark-100 group-hover:text-neon transition-colors duration-300">{p.name}</h3>
                    <span class="inline-flex items-center gap-1.5 mt-1.5"><span class="w-1.5 h-1.5 rounded-full bg-neon/50"></span><span class="text-xs font-mono text-neon/70 tracking-wide uppercase">{p.type}</span></span>
                  </div>
                  <div class="w-10 h-10 rounded-lg bg-dark-800 border border-dark-600 group-hover:border-neon/30 flex items-center justify-center transition-all duration-300 shrink-0">
                    <svg class="w-4 h-4 text-dark-500 group-hover:text-neon transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
                  </div>
                </div>
                <p class="text-sm text-dark-400 leading-relaxed mb-4">{p.desc}</p>
                {p.budget && <div class="flex gap-4 pt-4 border-t border-dark-700/50"><span class="text-xs font-mono text-dark-500"><span class="text-neon/60">$</span> {p.budget}</span><span class="text-xs font-mono text-dark-500"><span class="text-neon/60">@</span> {p.period}</span></div>}
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
