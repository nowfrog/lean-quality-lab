---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const lang = 'en';
---

<BaseLayout title="CE_IPSA | LQS Lab UniME" lang={lang}>
  <!-- Hero -->
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/projects/ce-ipsa/header.jpg" alt="Fosso Imperatore Industrial Park" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="inline-block bg-black/40 backdrop-blur-md rounded-2xl p-6 sm:p-8 border border-white/10">
      <span class="text-white font-mono text-sm tracking-widest uppercase">PRIN 2022 PNRR | NextGenerationEU</span>
      <h1 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl lg:text-7xl font-bold text-white mt-4 leading-tight">CE_IPSA</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl">A Development Model for Circular Economy between Industrial Parks and Surroundings Areas</p>
    </div></div>
  </section>
  <div class="gradient-line"></div>

  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Info box -->
      <div class="reveal bg-dark-900 border border-dark-700 rounded-2xl p-6 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Project Code</span>
            <p class="text-dark-100 font-mono mt-1">P20227NFA4</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Budget</span>
            <p class="text-dark-100 font-mono mt-1">&euro;266,000</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">Duration</span>
            <p class="text-dark-100 font-mono mt-1">24 months (2023-2026)</p>
          </div>
          <div>
            <span class="text-xs font-mono text-dark-500 uppercase">CUP</span>
            <p class="text-dark-100 font-mono mt-1 text-xs">UniOr C53D23008770001<br/>UniMe J53D23016630001</p>
          </div>
        </div>
      </div>

      <!-- The Project -->
      <div class="reveal mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">The Project</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">Circular Economy and Industrial Symbiosis</h2>
        <p class="text-dark-400 leading-relaxed mb-4">The <strong class="text-dark-100">CE_IPsa</strong> project studies the implementation of Industrial Symbiosis (IS) and Circular Economy (CE) to increase resource efficiency, environmental and social sustainability, and economic competitiveness in production areas.</p>
        <p class="text-dark-400 leading-relaxed mb-4">CE_IPsa builds a <strong class="text-dark-100">Development Model</strong> for industrial parks (IPs) combining <em class="text-dark-200">Grounded Theory</em> with Cost-Benefit Analysis and Multi-objective optimization. The industrial park becomes the reference subject with resource inflows and outflows; the surrounding areas become potential providers of secondary raw materials and destinations for by-products (re-use vs disposal).</p>
        <p class="text-dark-400 leading-relaxed">The research path is structured into five operational steps (RA1-RA5), from the theoretical literature review through to the development of a Decision Support System (DSS) for policymakers and entrepreneurs.</p>
      </div>

      <!-- Case Study: Fosso Imperatore -->
      <div class="reveal reveal-delay-1 mb-16">
        <span class="text-gold font-mono text-xs tracking-widest uppercase">Case Study</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">Fosso Imperatore Industrial Park</h2>
        <p class="text-dark-400 leading-relaxed mb-6">The case study is the Industrial Park of Nocera Inferiore, managed by the <strong class="text-dark-100">Consorzio di Imprese di Fosso Imperatore</strong>, in the Campania region. It is an ideal context for studying industrial symbiosis and circular economy in geographically limited areas: closing production loops is more feasible in small, well-defined contexts than at national scale.</p>

        <!-- Two side-by-side images -->
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div class="rounded-2xl overflow-hidden border border-dark-700">
            <img src="/images/projects/ce-ipsa/casestudy1.jpg" alt="Fosso Imperatore Industrial Park - view 1" class="w-full h-72 object-cover" loading="lazy" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-dark-700">
            <img src="/images/projects/ce-ipsa/casestudy2.jpg" alt="Fosso Imperatore Industrial Park - view 2" class="w-full h-72 object-cover" loading="lazy" />
          </div>
        </div>

        <!-- Full width image -->
        <div class="rounded-2xl overflow-hidden border border-dark-700">
          <img src="/images/projects/ce-ipsa/casestudy3.jpg" alt="Panoramic view of Fosso Imperatore Industrial Park" class="w-full h-80 object-cover" loading="lazy" />
          <div class="p-4 bg-dark-900">
            <p class="text-xs text-dark-400 italic">Fosso Imperatore Industrial Park, Nocera Inferiore (SA) | study area of the CE_IPSA project.</p>
          </div>
        </div>
      </div>

      <!-- Workshop / Stakeholder -->
      <div class="reveal reveal-delay-1 mb-16">
        <span class="text-cyan font-mono text-xs tracking-widest uppercase">Engagement</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-4">Workshops and Stakeholder Engagement</h2>
        <p class="text-dark-400 leading-relaxed mb-6">The project includes direct engagement activities with territorial stakeholders through workshops, roundtables, and discussion sessions with entrepreneurs, administrators, and researchers to co-design the circular development model.</p>

        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-2xl overflow-hidden border border-dark-700">
            <img src="/images/projects/ce-ipsa/ceipsa-stakeholder-workshop-speakers.jpeg" alt="CE_IPSA stakeholder workshop speakers" class="w-full h-72 object-cover" loading="lazy" />
            <div class="p-4 bg-dark-900">
              <p class="text-xs text-dark-400 italic">Plenary session of the stakeholder workshop.</p>
            </div>
          </div>
          <div class="rounded-2xl overflow-hidden border border-dark-700">
            <img src="/images/projects/ce-ipsa/ceipsa-panel-discussion-circular-economy.jpeg" alt="CE_IPSA circular economy panel discussion" class="w-full h-72 object-cover" loading="lazy" />
            <div class="p-4 bg-dark-900">
              <p class="text-xs text-dark-400 italic">Panel discussion on circular economy and industrial symbiosis.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Research Activities -->
      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-cyan font-mono text-xs tracking-widest uppercase">Research Activities</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">The Five Operational Steps</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { code: 'RA1', title: 'Theoretical Literature Review', desc: 'Systematic review of the literature on Industrial Symbiosis and Circular Economy: planning, monitoring, and evaluation of interventions in industrial parks.' },
            { code: 'RA2', title: 'Context Analysis', desc: 'Mapping of the production fabric of the selected industrial park and surrounding areas: resource flows, economic actors, infrastructure, and potential synergies.' },
            { code: 'RA3', title: 'Development Model Definition', desc: 'Construction of the Development Model integrating Grounded Theory, Cost-Benefit Analysis, and multi-objective optimization for the circular transition of the industrial park.' },
            { code: 'RA4', title: 'Development Plan Definition', desc: 'Elaboration of the operational Development Plan to implement the circular transition in the territory, with objectives, timelines, and performance indicators.' },
            { code: 'RA5', title: 'DSS Development', desc: 'Development of a Decision Support System for policymakers and entrepreneurs, supporting strategic decisions on circular economy implementation.' },
          ].map(ra => (
            <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-colors">
              <span class="text-xs font-mono text-neon font-bold">{ra.code}</span>
              <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100 mt-1">{ra.title}</h3>
              <p class="text-sm text-dark-400 mt-2">{ra.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal reveal-delay-2 mb-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-neon">&euro;266K</p>
            <p class="text-xs font-mono text-dark-500 mt-2 uppercase">Budget</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-cyan">2</p>
            <p class="text-xs font-mono text-dark-500 mt-2 uppercase">Research Units</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-gold">10</p>
            <p class="text-xs font-mono text-dark-500 mt-2 uppercase">Researchers</p>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl font-bold text-neon">9</p>
            <p class="text-xs font-mono text-dark-500 mt-2 uppercase">Publications</p>
          </div>
        </div>
      </div>

      <!-- Output / Publications -->
      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">Output</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">Publications</h2>
        <div class="space-y-4">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-all">
            <h4 class="font-[family-name:var(--font-display)] font-bold text-dark-100">Industrial Symbiosis Networks in Italian Industrial Parks: The Case of Fosso Imperatore</h4>
            <div class="flex flex-wrap items-center gap-3 mt-3">
              <span class="text-sm text-cyan italic">Springer</span>
              <span class="text-xs font-mono text-dark-500">2026</span>
              <span class="px-2 py-0.5 text-xs rounded-md bg-dark-800 border border-dark-700 text-dark-400 font-mono">Book Chapter</span>
            </div>
            <a href="https://doi.org/10.1007/978-3-032-09062-1_10" target="_blank" rel="noopener" class="inline-block mt-3 text-xs font-mono text-dark-500 hover:text-neon transition-colors">
              DOI: 10.1007/978-3-032-09062-1_10
            </a>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-all">
            <h4 class="font-[family-name:var(--font-display)] font-bold text-dark-100">A Circular Land Use Model for Reconciling Industrial Expansion with Agricultural Heritage</h4>
            <div class="flex flex-wrap items-center gap-3 mt-3">
              <span class="text-sm text-cyan italic">Sustainability</span>
              <span class="text-xs font-mono text-dark-500">2025</span>
              <span class="px-2 py-0.5 text-xs rounded-md bg-dark-800 border border-dark-700 text-dark-400 font-mono">Article</span>
            </div>
            <a href="https://doi.org/10.3390/su17198830" target="_blank" rel="noopener" class="inline-block mt-3 text-xs font-mono text-dark-500 hover:text-neon transition-colors">
              DOI: 10.3390/su17198830
            </a>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-5 hover:border-neon/20 transition-all">
            <h4 class="font-[family-name:var(--font-display)] font-bold text-dark-100">A Development Model for Circular Economy Between Industrial Parks and Surroundings Areas: The Reverse Logistics Strategic Approach</h4>
            <div class="flex flex-wrap items-center gap-3 mt-3">
              <span class="text-sm text-cyan italic">Springer</span>
              <span class="text-xs font-mono text-dark-500">2025</span>
              <span class="px-2 py-0.5 text-xs rounded-md bg-dark-800 border border-dark-700 text-dark-400 font-mono">Book Chapter</span>
            </div>
            <a href="https://doi.org/10.1007/978-3-031-80692-6_24" target="_blank" rel="noopener" class="inline-block mt-3 text-xs font-mono text-dark-500 hover:text-neon transition-colors">
              DOI: 10.1007/978-3-031-80692-6_24
            </a>
          </div>
        </div>
      </div>

      <!-- Team -->
      <div class="reveal reveal-delay-2 mb-16">
        <span class="text-neon font-mono text-xs tracking-widest uppercase">Team</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark-100 mt-3 mb-6">Research Team</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100 mb-3">Napoli L'Orientale (Lead)</h3>
            <ul class="space-y-2 text-sm text-dark-400">
              <li><span class="text-neon font-mono text-xs">PI</span> Roberta Arbolino</li>
              <li>Alessandra De Chiara</li>
              <li>Antonio Lopes</li>
              <li>Luisa De Simone</li>
              <li><span class="text-dark-500 font-mono text-xs">Recruited</span> Antonio Licastro</li>
              <li><span class="text-dark-500 font-mono text-xs">Recruited</span> Maria Coscia</li>
            </ul>
          </div>
          <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark-100 mb-3">UniME</h3>
            <ul class="space-y-2 text-sm text-dark-400">
              <li><span class="text-cyan font-mono text-xs">co-PI</span> Giuseppe Ioppolo</li>
              <li>Grazia Calabr&ograve;</li>
              <li>Giuseppe Caristi</li>
              <li><span class="text-dark-500 font-mono text-xs">Recruited</span> Carlotta D'Alessandro</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Link -->
      <div class="reveal reveal-delay-2">
        <a href="https://ceipsapnrr.github.io" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 border border-dark-600 hover:border-neon/50 text-dark-300 hover:text-neon font-medium rounded-lg transition-all hover:bg-neon/5 text-sm">
          Visit the project website
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
